<?php
ini_set('display_errors', 1);
error_reporting(E_ALL);


include_once __DIR__ . '/../../includes/rapid_opms.php';

/* ---------- HELPERS ---------- */
function inputValue($value) {
    if ($value === null) return '';
    if (trim($value) === '') return '';
    if ($value == 0) return '';
    return htmlspecialchars($value);
}
function num($key) {
    $val = $_POST[$key] ?? '';
    return $val === '' ? 0 : floatval(str_replace(',', '', $val));
}

/* ---------- GET PROJECT ---------- */
if (!isset($_GET['id'])) die("No project ID");
$id = (int)$_GET['id'];

$stmt = $conn->prepare("SELECT * FROM projects WHERE id=?");
$stmt->bind_param("i", $id);
$stmt->execute();
$project = $stmt->get_result()->fetch_assoc();
$stmt->close();

if (!$project) die("Project not found");

/* ---------- CUSTOMERS ---------- */
$customers = $conn->query("SELECT id, name, company_name FROM customers ORDER BY name ASC");

/* ---------- SAVE ---------- */
$errors = [];
if ($_SERVER['REQUEST_METHOD'] === 'POST') {

    $name = $_POST['name'];
    $date = $_POST['date'];
    $start_date = $_POST['start_date'];
    $status = $_POST['status'];        // ⭐ IMPORTANT
    $location = $_POST['location'];
    $contractor = $_POST['contractor'];
    $size = $_POST['size'];
    $customer_id = (int)$_POST['customer_id'];
    $project_manager = $_POST['project_manager'];
    $description = $_POST['description'];

    if (!$name) $errors[] = "Project name required";
    if (!$status) $errors[] = "Status required";

    if (!$errors) {
        $stmt = $conn->prepare("
        UPDATE projects SET
            name=?, date=?, start_date=?, status=?, location=?, contractor=?, size=?,
            customer_id=?, project_manager=?, description=?,

            straight_finish_area=?, straight_finish_unit_cost=?, straight_finish_amount=?,
            rough_finish_area=?, rough_finish_unit_cost=?, rough_finish_amount=?,
            suspended_volume_area=?, suspended_volume_unit_cost=?, suspended_volume_amount=?,
            mobilization_fee_area=?, mobilization_fee_unit_cost=?, mobilization_fee_amount=?,
            idle_time_area=?, idle_time_unit_cost=?, idle_time_amount=?,
            cancellation_fee_area=?, cancellation_fee_unit_cost=?, cancellation_fee_amount=?,
            total_amount=?
        WHERE id=?
        ");

        $stmt->bind_param(
            "ssssssisss".str_repeat("d",19)."i",
            $name,$date,$start_date,$status,$location,$contractor,$size,
            $customer_id,$project_manager,$description,

            num('straight_finish_area'),num('straight_finish_unit_cost'),num('straight_finish_amount'),
            num('rough_finish_area'),num('rough_finish_unit_cost'),num('rough_finish_amount'),
            num('suspended_volume_area'),num('suspended_volume_unit_cost'),num('suspended_volume_amount'),
            num('mobilization_fee_area'),num('mobilization_fee_unit_cost'),num('mobilization_fee_amount'),
            num('idle_time_area'),num('idle_time_unit_cost'),num('idle_time_amount'),
            num('cancellation_fee_area'),num('cancellation_fee_unit_cost'),num('cancellation_fee_amount'),
            num('total_amount'),
            $id
        );

        $stmt->execute();
        $_SESSION['success'] = "Project updated";
        header("Location: main.php?page=projects/view&id=".$id);
        exit;
    }
}
